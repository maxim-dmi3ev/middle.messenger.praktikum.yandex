@import "../../styles/colors.styl";

.chat-preview {
  position: relative;
  display: flex;
  padding: 10px 20px;
  cursor: pointer;
  border-bottom: 1px solid $border-default;

  &_selected {
    background-color: $background-grey1;
  }

  &:hover {
    background-color: $background-grey1;
  }

  &__aside {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  &__main {
    padding-right: 65px;
    padding-left: 20px;
  }

  &__aside-right {
    position: absolute;
    top: 0;
    right: 0;
    width: 70px;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  &__name {
    margin-top: 5px;
    font-size: 16px;
  }

  &__text {
    margin-top: 10px;
    font-size: 14px;
    color: $text-secondary;
  }

  &__time {
    font-size: 14px;
    color: $text-secondary;
  }

  &__counter {
    margin-top: 10px;
    width: 25px;
    height: 25px;
    background-color: $background-prime;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
  }
}
