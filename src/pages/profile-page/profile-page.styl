@import "../../styles/colors.styl"

.profile-page {
  &__header {
    padding: 30px;
  }

  &__go-back {
    font-size: 16px;
    color: $text-prime;
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }

  &__main {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  &__form {
    margin: 75px auto;
  }
}
