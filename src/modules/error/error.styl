@import "../../styles/colors.styl";

.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100px;

  &__code {
    font-size: 64px;
    color: $text-default;
  }

  &__text {
    margin-top: 30px;
    font-size: 36px;
    color: $text-default;
  }

  &__image {
    margin: 60px auto;
    width: 226px;
    height: 352px;

    img {
      display: block;
      width: 100%;
    }
  }

  &__go-back {
    font-size: 24px;
    color: $text-prime;
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }
}
